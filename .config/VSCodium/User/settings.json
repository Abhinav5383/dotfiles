{
	"json.schemaDownload.trustedDomains": {
		"https://schemastore.azurewebsites.net/": true,
		"https://raw.githubusercontent.com/microsoft/vscode/": true,
		"https://raw.githubusercontent.com/devcontainers/spec/": true,
		"https://www.schemastore.org/": true,
		"https://json.schemastore.org/": true,
		"https://json-schema.org/": true,
		"https://developer.microsoft.com/json-schemas/": true,
		"https://biomejs.dev": true
	},

	// indentation
	"editor.indentSize": 4,
	"editor.tabSize": 4,
	"editor.detectIndentation": false,
	"editor.insertSpaces": false,

	// fonts and themes
	"editor.fontFamily": "Monaspace Neon NF",
	"terminal.integrated.fontFamily": "Monaspace Neon NF",
	"editor.inlineSuggest.fontFamily": "Monaspace Krypton NF",
	"editor.fontLigatures": "'calt', 'liga', 'ss01', 'ss02', 'ss03', 'ss04', 'ss05', 'ss06', 'ss07', 'ss08', 'ss09'",
	"terminal.integrated.fontLigatures.enabled": true,
	"terminal.integrated.fontSize": 16,
	"editor.fontSize": 15,
	"workbench.iconTheme": "material-icon-theme",
	"workbench.colorTheme": "Monospace Dark",

	// ui
	"editor.minimap.enabled": false,
	"workbench.activityBar.location": "top",
	"editor.stickyScroll.enabled": false,
	"terminal.integrated.stickyScroll.enabled": false,
	"editor.cursorSmoothCaretAnimation": "on",
	"workbench.statusBar.visible": false,
	"window.customMenuBarAltFocus": false,

	// behaviour defaults
	"workbench.editor.languageDetection": false,
	"editor.defaultFormatter": "biomejs.biome",
	"notebook.defaultFormatter": "biomejs.biome",
	"extensions.autoUpdate": false,

	// lsps
	"editor.codeActionsOnSave": {
		"source.organizeImports": "always",
		"source.removeUnusedImports": "always"
	},

	"[json]": {
		"editor.suggest.insertMode": "replace",
		"editor.defaultFormatter": "biomejs.biome",
		"editor.quickSuggestions": {
			"strings": true
		}
	},
	"[jsonc]": {
		"editor.suggest.insertMode": "replace",
		"editor.defaultFormatter": "biomejs.biome",
		"editor.quickSuggestions": {
			"strings": true
		}
	},
	"[html]": {
		"editor.defaultFormatter": "vscode.html-language-features"
	},
	"[css]": {
		"editor.defaultFormatter": "vscode.css-language-features"
	},
	"[tailwindcss]": {
		"editor.defaultFormatter": "vscode.css-language-features"
	},
	"breadcrumbs.enabled": false,
	"terminal.integrated.initialHint": false
}
